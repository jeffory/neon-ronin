; Engine configuration file
; Do not edit manually

[application]

config/name="Neon Ronin"
run/main_scene="res://scenes/title_screen.tscn"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[physics]

common/physics_ticks_per_second=120
common/physics_interpolation=true
3d/physics_engine="Jolt Physics"

[rendering]

lights_and_shadows/directional_shadow/soft_shadow_filter_quality=3
anti_aliasing/quality/msaa_3d=2
environment/defaults/default_clear_color=Color(0.01, 0.01, 0.02, 1)

[layer_names]

3d_physics/layer_1="player"
3d_physics/layer_2="enemies"
3d_physics/layer_3="environment"
3d_physics/layer_4="pickups"

[autoload]

GameManager="*res://scripts/game_manager.gd"

